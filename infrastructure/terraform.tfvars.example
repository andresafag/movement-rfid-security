# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit real values.

aws_region   = "us-east-1"
project_name = "sensor-access"
environment  = "dev"

# VPC
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]
availability_zones   = ["us-east-1a", "us-east-1b"]

# IoT Core
iot_thing_name   = "esp32-sensor-01"
iot_topic_prefix = "sensors/motion"

# SNS — email recipients for sensor notifications
sns_subscriber_emails = [
  "andresfelipeacostagarcia34@gmail.com",
]

# Remote state — must be globally unique across all AWS accounts
state_bucket_name = "your-unique-tfstate-bucket-name"
